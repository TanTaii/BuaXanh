rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // === Helper Functions ===
    // Check if the current user is an Admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // === Users Collection ===
    match /users/{userId} {
      // Users can read/write their own profile; Admins can read/write all users
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Anyone can create a new user document during registration
      allow create: if isAuthenticated();
    }

    // === Products Collection ===
    match /products/{productId} {
      // Anyone (even guests) can view products
      allow read: if true;
      // Only Admins can create, update, or delete products
      allow write: if isAdmin();
    }

    // === Promotions Collection ===
    match /promotions/{promoId} {
      // Anyone can validate/read promotions
      allow read: if true;
      // Only Admins can manage promotions
      allow write: if isAdmin();
    }

    // === Orders Collection ===
    match /orders/{orderId} {
      // Users can only read their own orders; Admins can read all orders
      // Note: Make sure queries match these constraints, e.g. querying where("userId", "==", auth.uid)
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.userId);
      // Any authenticated user can create an order
      allow create: if isAuthenticated();
      // Only Admins can update order status or delete orders
      allow update, delete: if isAdmin();
    }

    // === Wishlist Collection ===
    match /wishlist/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // === Settings Collection ===
    // Stores global app settings (about us, general, contact info)
    match /settings/{document=**} {
      // Anyone can read store settings/info
      allow read: if true;
      // Only Admins can modify store settings
      allow write: if isAdmin();
    }
    
    // === Posts/Blogs Collection ===
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
